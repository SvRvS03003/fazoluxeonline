/*
 * JINLIHUA TEXTILE MONITORING SYSTEM v3.0 (ULTRA-MESH)
 * Core 0: RS485 / Modbus RTU
 * Core 1: Mesh / WebServer / UI
 */

#include "painlessMesh.h"
#include <ESPAsyncWebServer.h>
#include <ArduinoJson.h>

// --- CONFIGURATION ---
#define MESH_PREFIX "SvRvS_Industrial"
#define MESH_PASSWORD "vysoftfazo1965"
#define MESH_PORT 5555
#define NODE_ID 1 // Change this for each node (1 = Gateway)

#define RS485_TX 17
#define RS485_RX 16
#define RS485_CTRL 4

// --- DATA STRUCTURES ---
struct MachineData {
  uint16_t id;
  float meters;
  float shift_meters;
  float asnova_length;
  uint16_t speed;
  uint32_t last_seen;
  bool online;
};

MachineData looms[69]; // 1-68
painlessMesh mesh;
AsyncWebServer server(80);

// --- RS485 / MODBUS (CORE 0) ---
void rs485Task(void * pvParameters) {
  Serial2.begin(9600, SERIAL_8N1, RS485_RX, RS485_TX);
  pinMode(RS485_CTRL, OUTPUT);
  digitalWrite(RS485_CTRL, LOW);

  for(;;) {
    // Basic Modbus Fake/Real Polling Logic
    // In production: Read Function 03 from Slave 1
    looms[NODE_ID].meters += 0.1; // Demo increment
    looms[NODE_ID].last_seen = millis();
    looms[NODE_ID].online = true;
    vTaskDelay(1000 / portTICK_PERIOD_MS);
  }
}

// --- MESH (CORE 1) ---
void receivedCallback(uint32_t from, String &msg) {
  StaticJsonDocument<512> doc;
  deserializeJson(doc, msg);
  int id = doc["id"];
  if (id > 0 && id <= 68) {
    looms[id].meters = doc["m"];
    looms[id].speed = doc["s"];
    looms[id].asnova_length = doc["a"];
    looms[id].last_seen = millis();
    looms[id].online = true;
  }
}

