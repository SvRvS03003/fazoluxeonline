void setup() {
  Serial.begin(115200);
  
  // Mesh Setup
  mesh.setDebugMsgTypes(ERROR | STARTUP);
  mesh.init(MESH_PREFIX, MESH_PASSWORD, MESH_PORT);
  mesh.onReceive(&receivedCallback);

  if (NODE_ID == 1) { // Gateway
    server.on("/data", HTTP_GET, [](AsyncWebServerRequest *request){
      DynamicJsonDocument doc(16384);
      for(int i=1; i<=68; i++) {
        JsonObject obj = doc.createNestedObject(String(i));
        obj["m"] = looms[i].meters;
        obj["a"] = looms[i].asnova_length;
        obj["o"] = (millis() - looms[i].last_seen < 10000);
      }
      String json;
      serializeJson(doc, json);
      request->send(200, "application/json", json);
    });

    server.on("/set", HTTP_GET, [](AsyncWebServerRequest *request){
      int id = request->getParam("id")->value().toInt();
      float val = request->getParam("val")->value().toFloat();
      if (id > 0 && id <= 68) looms[id].asnova_length = val;
      request->send(200, "text/plain", "OK");
    });

    server.on("/", HTTP_GET, [](AsyncWebServerRequest *request){
      request->send_P(200, "text/html", index_html);
    });

    server.begin();
    Serial.println("Web Server Started (Gateway)");
  }

  // Create RS485 Task on Core 0
  xTaskCreatePinnedToCore(rs485Task, "RS485", 4096, NULL, 1, NULL, 0);
}

void loop() {
  mesh.update();
  
  // Every 2s, Slaves send their data to Gateway
  static unsigned long lastUpdate = 0;
  if (NODE_ID != 1 && millis() - lastUpdate > 2000) {
    StaticJsonDocument<256> doc;
    doc["id"] = NODE_ID;
    doc["m"] = looms[NODE_ID].meters;
    doc["s"] = looms[NODE_ID].speed;
    doc["a"] = looms[NODE_ID].asnova_length;
    String msg;
    serializeJson(doc, msg);
    mesh.sendBroadcast(msg);
    lastUpdate = millis();
  }
}
